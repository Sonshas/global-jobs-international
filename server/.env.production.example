# =============================================================================
# Server — production (on the VPS: /var/www/global-jobs-international/server/.env)
# chmod 600 this file. Never commit it.
# =============================================================================
PORT=3001
HOST=127.0.0.1
NODE_ENV=production
APP_ENV=production

# Apex + www (comma-separated). Must match the browser origin(s) exactly.
CLIENT_ORIGIN=https://globaljobsinternational.com,https://www.globaljobsinternational.com
PUBLIC_APP_URL=https://globaljobsinternational.com

# REQUIRED — dedicated production Supabase project
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PRODUCTION_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_PRODUCTION_SERVICE_ROLE_KEY

# REQUIRED for production email
RESEND_API_KEY=YOUR_RESEND_API_KEY
EMAIL_FROM=Global Jobs International <noreply@globaljobsinternational.com>

# REQUIRED for Stripe Checkout
STRIPE_SECRET_KEY=sk_live_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me

# REQUIRED for unattended interview reminders
CRON_SECRET=replace-with-long-random-secret
