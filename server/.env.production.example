# =============================================================================
# Server — production (copy to server/.env.production or host secrets)
# =============================================================================
PORT=3001
NODE_ENV=production
APP_ENV=production
CLIENT_ORIGIN=https://www.example.com

# REQUIRED — dedicated production Supabase project
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key
# REQUIRED — server/host secrets only (never Vite / browser)
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# REQUIRED for production email delivery
RESEND_API_KEY=your-resend-api-key
# Must use a domain verified in Resend
EMAIL_FROM=Global Jobs International <noreply@example.com>

# REQUIRED for Stripe Checkout; server-only values from Stripe Dashboard.
STRIPE_SECRET_KEY=sk_live_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me
# Public HTTPS SPA origin for Checkout redirects.
PUBLIC_APP_URL=https://www.example.com
