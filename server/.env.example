# =============================================================================
# Server — development (copy to server/.env)
# =============================================================================
# Required before the API will start. Values must NOT be placeholders.
#
# Where to get secrets:
#   SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
#     → Supabase Dashboard → Project Settings → API
#   RESEND_API_KEY / EMAIL_FROM
#     → https://resend.com (API keys + verified domain)
#
# Never put the service_role key in client/.env or any VITE_* variable.
# =============================================================================

PORT=3001
NODE_ENV=development
APP_ENV=development
# Must match the browser origin serving the SPA
CLIENT_ORIGIN=http://localhost:5173

# REQUIRED — same project as client/.env VITE_SUPABASE_*
SUPABASE_URL=https://your-dev-project.supabase.co
SUPABASE_ANON_KEY=your-dev-anon-key

# OPTIONAL in development (JWT routes + Sprint 3 verifier work without it).
# REQUIRED on staging/production servers.
# SUPABASE_SERVICE_ROLE_KEY=

# OPTIONAL in development — emails log to the server console when unset.
# REQUIRED in production.
# RESEND_API_KEY=
EMAIL_FROM=Global Jobs International <noreply@globaljobs.international>

# Stripe Checkout (SECRET). Leave blank locally unless testing payments.
# Required in production; configure Stripe to send webhooks to /api/payments/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional locally; production redirect origin (for example https://app.example.com).
PUBLIC_APP_URL=http://localhost:5173
