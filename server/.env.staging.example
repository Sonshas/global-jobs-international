# =============================================================================
# Server — staging (copy to server/.env.staging or host secrets)
# =============================================================================
PORT=3001
NODE_ENV=production
APP_ENV=staging
CLIENT_ORIGIN=https://staging.example.com

# REQUIRED — dedicated staging Supabase project
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key
# REQUIRED — server/host secrets only (never Vite)
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# OPTIONAL on staging (log mode if unset). Recommended before production cutover.
# RESEND_API_KEY=
EMAIL_FROM=Global Jobs International <noreply@staging.example.com>
