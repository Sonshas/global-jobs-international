# =============================================================================
# Client — development (copy to client/.env)
# Public values only. Never put service_role or Resend keys here.
# =============================================================================
VITE_APP_ENV=development
# Express API base INCLUDING /api
VITE_API_URL=http://localhost:3001/api
# Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
# Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-dev-anon-key

# Strict RBAC is recommended once roles are seeded.
VITE_STRICT_RBAC=true
# Opt-in local UI exploration without DB roles — NEVER true outside development
VITE_ALLOW_DEMO_ADMIN=false

# Optional in development (defaults to window.location.origin for auth emails).
# VITE_PUBLIC_SITE_URL=http://localhost:5173
#
# Production builds MUST set VITE_PUBLIC_SITE_URL in client/.env.production
# (see .env.production.example). Auth emailRedirectTo uses that value, not localhost.
#
# Supabase Dashboard → Authentication → URL Configuration (production):
#   Site URL: https://globaljobsinternational.com
#   Redirect URLs:
#     https://globaljobsinternational.com/auth/callback
#     https://globaljobsinternational.com/auth/reset-password
#     https://globaljobsinternational.com/verify-email
