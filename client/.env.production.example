# =============================================================================
# Client — production (copy to client/.env.production BEFORE `npm run build`)
# Public values only. Never put service_role / Resend / Stripe secrets here.
# Vite inlines these at build time — missing values cause a blank white page.
# =============================================================================
VITE_APP_ENV=production

# Preferred: same-origin path (Nginx proxies /api → Express :3001)
VITE_API_URL=/api

# Canonical public site (auth emailRedirectTo / password reset, sitemap, OG)
# Must be the live HTTPS origin — never localhost in production builds.
VITE_PUBLIC_SITE_URL=https://globaljobsinternational.com

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
VITE_STRICT_RBAC=true
VITE_ALLOW_DEMO_ADMIN=false
# Leave unset so public pages stay DB-only:
# VITE_ALLOW_SAMPLE_CATALOG=false
