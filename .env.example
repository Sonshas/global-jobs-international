# =============================================================================
# Global Jobs International — complete environment template
# =============================================================================
# This file documents EVERY variable used by the monorepo.
#
# Actual runtime files (do not commit secrets):
#   client/.env                 development SPA
#   client/.env.staging         staging SPA build
#   client/.env.production      production SPA build
#   server/.env                 development API
#   server/.env.staging         staging API
#   server/.env.production      production API
#
# Copy sections into the matching file. Never put service_role or Resend keys
# in any VITE_* / client env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Playwright E2E (optional — root or shell env)
# -----------------------------------------------------------------------------
# Base URL for the SPA under test.
E2E_BASE_URL=http://localhost:5173
# Set to 1 when the site is already running (do not start Vite from Playwright).
# E2E_SKIP_WEB_SERVER=1
# Staging credentials for authenticated flow tests (skipped if unset).
# E2E_APPLICANT_EMAIL=
# E2E_APPLICANT_PASSWORD=
# E2E_EMPLOYER_EMAIL=
# E2E_EMPLOYER_PASSWORD=
# Catalog job id from /jobs browse for apply-wizard smoke.
# E2E_CATALOG_JOB_ID=

# -----------------------------------------------------------------------------
# Client (Vite) — public values only. File: client/.env*
# -----------------------------------------------------------------------------
# development | staging | production
VITE_APP_ENV=development
# Express API base INCLUDING /api (e.g. http://localhost:3001/api)
VITE_API_URL=http://localhost:3001/api
# Supabase Project URL (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
# Supabase anon/public key ONLY (never service_role)
VITE_SUPABASE_ANON_KEY=your-dev-anon-key
# Enforce Postgres-backed roles (must be true in staging/production)
VITE_STRICT_RBAC=true
# Local UI privilege bypass — MUST stay false in staging/production
VITE_ALLOW_DEMO_ADMIN=false
# Allow the generated sample job catalog to appear alongside real DB data.
# Always true in `import.meta.env.DEV`. Leave unset/false in staging and
# production so public pages (jobs search, job detail, stats) are DB-only.
# VITE_ALLOW_SAMPLE_CATALOG=false

# -----------------------------------------------------------------------------
# Server (Express) — private. File: server/.env*
# -----------------------------------------------------------------------------
PORT=3001
# development | test | production (Node runtime mode)
NODE_ENV=development
# development | staging | production (product environment)
APP_ENV=development
# Exact SPA origin for CORS (must match the browser origin)
CLIENT_ORIGIN=http://localhost:5173

# Same Supabase project as the client for this environment
# Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-dev-project.supabase.co
# Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=your-dev-anon-key

# Dashboard → Project Settings → API → service_role (SECRET)
# Required: staging + production server hosts / secret managers
# Optional: local development (JWT-authorized routes work without it;
#           Sprint 3 verifier uses linked CLI instead of this key)
# Configure ONLY on the server: server/.env, Hostinger/VPS env, CI secrets,
# or a secrets manager. NEVER in client/.env or any VITE_* variable.
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email via Resend (SECRET) — https://resend.com
# Required: production (APP_ENV=production)
# Optional: development/staging (without it, emails are logged only)
# Configure ONLY on the server host / secrets manager.
RESEND_API_KEY=
# From header; must use a domain verified in Resend for real delivery.
EMAIL_FROM=Global Jobs International <noreply@globaljobs.international>

# Stripe Checkout (server-only secrets). Required in production; blank locally
# unless testing. Configure Stripe webhook delivery at /api/payments/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public SPA URL used by Stripe success/cancel redirects.
PUBLIC_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Per-environment requirements (summary)
# -----------------------------------------------------------------------------
# Development (local):
#   REQUIRED client: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_API_URL
#   REQUIRED server: SUPABASE_URL, SUPABASE_ANON_KEY, CLIENT_ORIGIN, APP_ENV, NODE_ENV
#   OPTIONAL server: SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, EMAIL_FROM
#
# Staging:
#   REQUIRED client: all VITE_* above (ALLOW_DEMO_ADMIN=false, STRICT_RBAC=true)
#   REQUIRED server: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#                    CLIENT_ORIGIN, APP_ENV=staging, NODE_ENV=production
#   OPTIONAL server: RESEND_API_KEY, EMAIL_FROM (log mode if unset)
#
# Production:
#   REQUIRED client: all VITE_* (ALLOW_DEMO_ADMIN=false, STRICT_RBAC=true)
#   REQUIRED server: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#                    RESEND_API_KEY, EMAIL_FROM, CLIENT_ORIGIN,
#                    APP_ENV=production, NODE_ENV=production
